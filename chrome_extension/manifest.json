{
  "manifest_version": 3,
  "name": "Phishing Detector Tools",
  "version": "1.0",
  "description": "Real-time phishing website detection tool.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Check Phishing Status"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}
